# Font configuration
font-family = "Berkeley Mono Variable"
font-size = 14
font-variation = wdth=90
font-variation = wght=500

# Theme configuration
# Automatically switches between light and dark themes based on system appearance
theme = light:Gruvbox Light Hard,dark:Gruvbox Dark Hard

# Window configuration
# background-blur-radius = 20
# background-opacity = 0.95
window-padding-x = 10
window-padding-y = 10

# Shell integration
# ssh-terminfo copies xterm-ghostty terminfo to remote hosts, falling back to xterm-256color.
shell-integration-features = ssh-env,ssh-terminfo

# Keybindings
keybind = global:ctrl+alt+super+t=toggle_quick_terminal
keybind = alt+left=unbind
keybind = alt+right=unbind
# Ignore F13 (used for push to talk)
keybind = f13=ignore

# Allows shift+enter to insert new lines in Claude Code
keybind = shift+enter=text:\x1b\r

# Startup
# initial-command = /opt/homebrew/bin/fish -c "zellij ls | grep main && zellij attach main || zellij -s main"
